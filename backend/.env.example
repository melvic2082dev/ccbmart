# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL required — local via docker-compose or remote Railway)
# Add connection_limit and pool_timeout for production connection pooling
DATABASE_URL=postgresql://user:password@localhost:5432/ccbmart?connection_limit=20&pool_timeout=10

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (leave empty to use in-memory cache fallback)
# Set REDIS_PASSWORD to enable authentication — required in production
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-southeast-1

# MoMo Payment
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn

# ZaloPay
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_API_URL=https://sb-openapi.zalopay.vn

# KiotViet
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_RETAILER=
KIOTVIET_API_URL=
KIOTVIET_WEBHOOK_SECRET=

# Bank Account (for QR / transfer content)
BANK_NAME=Vietcombank
BANK_ACCOUNT_NO=xxxx-xxxx
BANK_ACCOUNT_NAME=CONG TY TNHH CCB MART

# Combo pricing
COMBO_PRICE=2000000
COMBO_COGS_PCT=0.50

# Dashboard targets
DASHBOARD_REVENUE_TARGET=600000000
DASHBOARD_NET_PROFIT_TARGET=30000000
