# Server
NODE_ENV=development
PORT=4000

# Database (postgresql for production, sqlite for dev)
# Add connection_limit and pool_timeout for production connection pooling
DATABASE_URL=postgresql://user:password@localhost:5432/ccbmart?connection_limit=20&pool_timeout=10

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (leave empty to use in-memory cache fallback)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-southeast-1

# MoMo Payment
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ZaloPay
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# KiotViet
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_RETAILER=
