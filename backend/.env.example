# Server
NODE_ENV=development
PORT=8080

# Database (PostgreSQL required — local via docker-compose or remote Railway)
# Add connection_limit and pool_timeout for production connection pooling
DATABASE_URL=postgresql://user:password@localhost:5432/ccbmart?connection_limit=20&pool_timeout=10

# JWT — access token (short-lived)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=15m

# JWT — refresh token (long-lived, will be httpOnly cookie in P2)
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# CSRF double-submit cookie secret (used in P2)
CSRF_SECRET=your-csrf-secret-here

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (leave empty to use in-memory cache fallback)
# Set REDIS_PASSWORD to enable authentication — required in production
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-southeast-1

# MoMo Payment
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn

# ZaloPay
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_API_URL=https://sb-openapi.zalopay.vn

# KiotViet
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_RETAILER=
KIOTVIET_API_URL=
KIOTVIET_WEBHOOK_SECRET=

# Bank Account (for QR / transfer content)
BANK_NAME=Vietcombank
BANK_ACCOUNT_NO=xxxx-xxxx
BANK_ACCOUNT_NAME=CONG TY TNHH CCB MART

# Combo pricing
COMBO_PRICE=2000000
COMBO_COGS_PCT=0.50

# Dashboard targets
DASHBOARD_REVENUE_TARGET=600000000
DASHBOARD_NET_PROFIT_TARGET=30000000

# Observability (P0 scaffolding — optional, no-op if empty)
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.1
LOG_LEVEL=info

# Feature flags (P0 — read by services in later phases)
ENABLE_SOFT_SALARY=true
ENABLE_K_FACTOR=true
REFERRAL_CAP_AMOUNT=2000000
REFERRAL_SUNSET_MONTHS=12
TRAINING_REQUIRED_HOURS=20

# Worker process role (P4) — leave empty for now, set to "worker" on worker service
WORKER_ROLE=
