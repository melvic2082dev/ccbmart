generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   // ctv, agency, admin
  name          String
  phone         String?
  rank          String?  // CTV, PP, TP, GDV, GDKD
  parentId      Int?     @map("parent_id")
  agencyId      Int?     @map("agency_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  parent        User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children      User[]   @relation("UserHierarchy")
  agency        Agency?  @relation("AgencyUser", fields: [agencyId], references: [id])

  managedCtvs   CtvHierarchy[] @relation("Manager")
  asCtvEntry    CtvHierarchy[] @relation("Ctv")
  transactions  Transaction[]  @relation("CtvTransactions")
  customers     Customer[]     @relation("CtvCustomers")
  kpiLogs       KpiLog[]
  rankHistory   RankHistory[]
  ownedAgency   Agency?        @relation("AgencyOwner")
  notifications Notification[]
  cashDeposits        CashDeposit[] @relation("CtvDeposits")
  confirmedDeposits   CashDeposit[] @relation("AdminConfirmedDeposits")
  memberWallet        MemberWallet? @relation("MemberWallet")
  pushSubscriptions   PushSubscription[]
  importLogs          ImportLog[]
  promotionEligibilities PromotionEligibility[] @relation("CtvPromotions")
  teamBonuses         TeamBonus[]    @relation("CtvTeamBonuses")
  loyaltyPoints       LoyaltyPoint[] @relation("UserLoyaltyPoints")
  professionalTitle   ProfessionalTitle?

  @@index([parentId])
  @@index([rank])
  @@index([role])
  @@index([role, isActive])
  @@map("users")
}

model CtvHierarchy {
  id          Int      @id @default(autoincrement())
  ctvId       Int      @map("ctv_id")
  managerId   Int      @map("manager_id")
  level       String   // DIRECT, INDIRECT2, INDIRECT3
  appointedAt DateTime @default(now()) @map("appointed_at")

  ctv         User     @relation("Ctv", fields: [ctvId], references: [id])
  manager     User     @relation("Manager", fields: [managerId], references: [id])

  @@map("ctv_hierarchy")
}

model Agency {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  name            String
  depositAmount   Float    @map("deposit_amount")
  depositTier     String   @map("deposit_tier")
  address         String?

  user            User     @relation("AgencyOwner", fields: [userId], references: [id])
  users           User[]   @relation("AgencyUser")
  transactions    Transaction[] @relation("AgencyTransactions")
  customers       Customer[]    @relation("AgencyCustomers")
  inventoryWarnings InventoryWarning[]

  @@map("agencies")
}

model CommissionConfig {
  id            Int    @id @default(autoincrement())
  tier          String @unique
  selfSalePct   Float  @map("self_sale_pct")
  directPct     Float  @map("direct_pct")
  indirect2Pct  Float  @map("indirect2_pct")
  indirect3Pct  Float  @map("indirect3_pct")
  fixedSalary   Float  @map("fixed_salary")

  @@map("commission_config")
}

model AgencyCommissionConfig {
  id            Int    @id @default(autoincrement())
  group         String @unique
  commissionPct Float  @map("commission_pct")
  bonusPct      Float  @map("bonus_pct")

  @@map("agency_commission_config")
}

model Product {
  id       Int    @id @default(autoincrement())
  name     String
  category String
  price    Float
  cogsPct  Float  @map("cogs_pct")
  unit     String

  transactionItems TransactionItem[]
  inventoryWarnings InventoryWarning[]

  @@map("products")
}

model Transaction {
  id              Int      @id @default(autoincrement())
  kiotvietOrderId String?  @map("kiotviet_order_id")
  customerId      Int?     @map("customer_id")
  ctvId           Int?     @map("ctv_id")
  agencyId        Int?     @map("agency_id")
  channel         String   // ctv, agency, showroom
  totalAmount     Float    @map("total_amount")
  cogsAmount      Float    @map("cogs_amount")
  status          String   @default("CONFIRMED") // PENDING, CONFIRMED, REJECTED
  paymentMethod   String?  @map("payment_method") // bank_transfer, cash
  bankCode        String?  @map("bank_code") // last 4 digits
  qrCodeData      String?  @map("qr_code_data")
  bankReference   String?  @map("bank_reference")
  ctvSubmittedAt  DateTime? @map("ctv_submitted_at")
  confirmedBy     Int?     @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  rejectedReason  String?  @map("rejected_reason")
  cashDepositId   Int?     @map("cash_deposit_id")
  createdAt       DateTime @default(now()) @map("created_at")

  customer        Customer?    @relation(fields: [customerId], references: [id])
  ctv             User?        @relation("CtvTransactions", fields: [ctvId], references: [id])
  agency          Agency?      @relation("AgencyTransactions", fields: [agencyId], references: [id])
  items           TransactionItem[]
  paymentProof    PaymentProof?
  cashDeposit     CashDeposit? @relation(fields: [cashDepositId], references: [id])

  @@index([ctvId])
  @@index([agencyId])
  @@index([channel])
  @@index([createdAt])
  @@index([status])
  @@index([ctvId, status])
  @@index([ctvId, createdAt])
  @@index([agencyId, createdAt])
  @@index([channel, createdAt])
  @@map("transactions")
}

model TransactionItem {
  id            Int    @id @default(autoincrement())
  transactionId Int    @map("transaction_id")
  productId     Int    @map("product_id")
  quantity      Int
  unitPrice     Float  @map("unit_price")
  totalPrice    Float  @map("total_price")

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  ctvId         Int?     @map("ctv_id")
  agencyId      Int?     @map("agency_id")
  firstPurchase DateTime? @map("first_purchase")
  totalSpent    Float    @default(0) @map("total_spent")

  ctv           User?    @relation("CtvCustomers", fields: [ctvId], references: [id])
  agency        Agency?  @relation("AgencyCustomers", fields: [agencyId], references: [id])
  transactions  Transaction[]
  memberWallet  MemberWallet?

  @@map("customers")
}

model KpiLog {
  id            Int    @id @default(autoincrement())
  ctvId         Int    @map("ctv_id")
  month         String
  selfSales     Int    @map("self_sales")
  portfolioSize Int    @map("portfolio_size")
  rankBefore    String @map("rank_before")
  rankAfter     String @map("rank_after")

  ctv           User   @relation(fields: [ctvId], references: [id])

  @@unique([ctvId, month])
  @@index([month])
  @@map("kpi_logs")
}

model RankHistory {
  id        Int      @id @default(autoincrement())
  ctvId     Int      @map("ctv_id")
  oldRank   String   @map("old_rank")
  newRank   String   @map("new_rank")
  reason    String
  changedAt DateTime @default(now()) @map("changed_at")
  changedBy String   @map("changed_by")

  ctv       User     @relation(fields: [ctvId], references: [id])

  @@map("rank_history")
}

model InventoryWarning {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  agencyId    Int?     @map("agency_id")
  quantity    Int
  expiryDate  DateTime @map("expiry_date")
  warningType String   @map("warning_type")
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id])
  agency      Agency?  @relation(fields: [agencyId], references: [id])

  @@map("inventory_warnings")
}

model SyncLog {
  id            Int      @id @default(autoincrement())
  source        String
  recordsSynced Int      @map("records_synced")
  syncedAt      DateTime @default(now()) @map("synced_at")
  status        String

  @@map("sync_logs")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  title     String
  content   String
  metadata  String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model PaymentProof {
  id            Int      @id @default(autoincrement())
  transactionId Int      @unique @map("transaction_id")
  imageUrl      String   @map("image_url")
  uploadedBy    Int      @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")
  notes         String?

  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("payment_proofs")
}

model CashDeposit {
  id             Int       @id @default(autoincrement())
  ctvId          Int       @map("ctv_id")
  amount         Float
  transactionIds String    @map("transaction_ids") // JSON array
  depositedAt    DateTime  @default(now()) @map("deposited_at")
  confirmedBy    Int?      @map("confirmed_by")
  confirmedAt    DateTime? @map("confirmed_at")
  status         String    @default("PENDING") // PENDING, CONFIRMED, REJECTED
  notes          String?

  ctv            User      @relation("CtvDeposits", fields: [ctvId], references: [id])
  confirmAdmin   User?     @relation("AdminConfirmedDeposits", fields: [confirmedBy], references: [id])
  transactions   Transaction[]

  @@index([ctvId])
  @@index([status])
  @@map("cash_deposits")
}

model KpiConfig {
  id              Int    @id @default(autoincrement())
  rank            String @unique
  minSelfCombo    Int    @map("min_self_combo")
  minPortfolio    Int    @map("min_portfolio")
  fallbackRank    String @map("fallback_rank")

  @@map("kpi_config")
}

model CogsConfig {
  id          Int    @id @default(autoincrement())
  phase       String @unique
  name        String
  cogsPct     Float  @map("cogs_pct")
  description String?

  @@map("cogs_config")
}

model MembershipTier {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  minDeposit         Float    @map("min_deposit")
  discountPct        Float    @map("discount_pct")
  referralPct        Float    @map("referral_pct")
  monthlyReferralCap Float    @map("monthly_referral_cap")
  color              String   @default("gray")
  createdAt          DateTime @default(now()) @map("created_at")

  wallets            MemberWallet[]

  @@map("membership_tiers")
}

model MemberWallet {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  customerId            Int?     @unique @map("customer_id")
  tierId                Int      @map("tier_id")
  balance               Float    @default(0)
  totalDeposit          Float    @default(0) @map("total_deposit")
  referralCode          String   @unique @map("referral_code")
  referredById          Int?     @map("referred_by_id")
  referralEarned        Float    @default(0) @map("referral_earned")
  monthlyReferralEarned Float    @default(0) @map("monthly_referral_earned")
  createdAt             DateTime @default(now()) @map("created_at")

  user                  User              @relation("MemberWallet", fields: [userId], references: [id])
  customer              Customer?         @relation(fields: [customerId], references: [id])
  tier                  MembershipTier    @relation(fields: [tierId], references: [id])
  referredBy            MemberWallet?     @relation("Referrals", fields: [referredById], references: [id])
  referrals             MemberWallet[]    @relation("Referrals")
  deposits              DepositHistory[]
  commissionsEarned     ReferralCommission[] @relation("CommissionEarner")
  commissionsGenerated  ReferralCommission[] @relation("CommissionGenerator")

  @@index([referralCode])
  @@index([tierId])
  @@map("member_wallets")
}

model DepositHistory {
  id          Int       @id @default(autoincrement())
  walletId    Int       @map("wallet_id")
  amount      Float
  method      String    // bank_transfer, cash, momo, zalopay
  status      String    @default("PENDING")
  provider    String?   // momo, zalopay
  providerTxId String?  @map("provider_tx_id")
  confirmedBy Int?      @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  wallet      MemberWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@map("deposit_history")
}

model ReferralCommission {
  id              Int      @id @default(autoincrement())
  earnerWalletId  Int      @map("earner_wallet_id")
  sourceWalletId  Int      @map("source_wallet_id")
  amount          Float
  ratePct         Float    @map("rate_pct")
  month           String
  createdAt       DateTime @default(now()) @map("created_at")

  earnerWallet    MemberWallet @relation("CommissionEarner", fields: [earnerWalletId], references: [id])
  sourceWallet    MemberWallet @relation("CommissionGenerator", fields: [sourceWalletId], references: [id])

  @@index([earnerWalletId])
  @@index([month])
  @@map("referral_commissions")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

model ImportLog {
  id          Int      @id @default(autoincrement())
  type        String   // ctv, product, agency, member
  fileName    String   @map("file_name")
  totalRows   Int      @map("total_rows")
  successRows Int      @map("success_rows")
  failedRows  Int      @map("failed_rows")
  importedBy  Int      @map("imported_by")
  importedAt  DateTime @default(now()) @map("imported_at")
  details     String?  // JSON

  importer    User     @relation(fields: [importedBy], references: [id])

  @@map("import_logs")
}

// ===== V10 NEW MODELS =====

model PromotionEligibility {
  id              Int       @id @default(autoincrement())
  ctvId           Int       @map("ctv_id")
  targetRank      String    @map("target_rank")
  qualifiedMonth  String    @map("qualified_month")
  effectiveDate   DateTime  @map("effective_date")
  status          String    @default("PENDING") // PENDING, APPROVED, ACTIVATED
  approvedBy      Int?      @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  ctv             User      @relation("CtvPromotions", fields: [ctvId], references: [id])

  @@map("promotion_eligibility")
}

model TeamBonus {
  id                  Int       @id @default(autoincrement())
  ctvId               Int       @map("ctv_id")
  month               String
  directMemberCount   Int       @map("direct_member_count")
  teamRevenue         Float     @map("team_revenue")
  bonusRate           Float     @map("bonus_rate")
  bonusAmount         Float     @map("bonus_amount")
  cashAmount          Float     @map("cash_amount")
  pointAmount         Float     @map("point_amount")
  status              String    @default("PENDING")
  paidAt              DateTime? @map("paid_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  ctv                 User      @relation("CtvTeamBonuses", fields: [ctvId], references: [id])

  @@map("team_bonuses")
}

model LoyaltyPoint {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  points      Int
  source      String    // TEAM_BONUS, PERSONAL_PURCHASE, MILESTONE
  referenceId Int?      @map("reference_id")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation("UserLoyaltyPoints", fields: [userId], references: [id])

  @@map("loyalty_points")
}

model ProfessionalTitle {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique @map("user_id")
  title       String    // EXPERT_LEADER, SENIOR_EXPERT, STRATEGIC_ADVISOR
  directCount Int       @map("direct_count")
  awardedAt   DateTime  @default(now()) @map("awarded_at")
  renewedAt   DateTime  @map("renewed_at")
  expiresAt   DateTime  @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  user        User      @relation(fields: [userId], references: [id])

  @@map("professional_titles")
}
