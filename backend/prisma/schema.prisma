generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   // ctv, agency, admin
  name          String
  phone         String?
  rank          String?  // CTV, PP, TP, GDV, GDKD (chức danh chuyên nghiệp)
  parentId      Int?     @map("parent_id")
  agencyId      Int?     @map("agency_id")
  isActive      Boolean  @default(true) @map("is_active")
  isBusinessHousehold Boolean @default(false) @map("is_business_household")
  // Multi-capability: user có thể vừa CTV vừa Member (mua hàng cá nhân + tích điểm)
  isMember      Boolean  @default(false) @map("is_member")
  createdAt     DateTime @default(now()) @map("created_at")

  // V12.2: eKYC
  kycStatus       String    @default("PENDING") @map("kyc_status") // PENDING/SUBMITTED/VERIFIED/REJECTED/NEED_MANUAL_REVIEW
  kycSubmittedAt  DateTime? @map("kyc_submitted_at")
  kycVerifiedAt   DateTime? @map("kyc_verified_at")
  kycRejectReason String?   @map("kyc_reject_reason")
  idNumber        String?   @unique @map("id_number")
  idFrontImage    String?   @map("id_front_image")
  idBackImage     String?   @map("id_back_image")

  // C12.3: eKYC manual override
  kycMethod       String    @default("AUTO") @map("kyc_method") // AUTO, MANUAL, HYBRID
  kycManualNote   String?   @map("kyc_manual_note")
  kycVerifiedBy   Int?      @map("kyc_verified_by")

  // V13.3: eKYC "3 duy nhất" — CCCD (idNumber @unique), deviceId + IP tracked on submit
  kycDeviceId     String?   @map("kyc_device_id")
  kycIpAddress    String?   @map("kyc_ip_address")

  parent        User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children      User[]   @relation("UserHierarchy")
  agency        Agency?  @relation("AgencyUser", fields: [agencyId], references: [id])

  managedCtvs         CtvHierarchy[]       @relation("Manager")
  asCtvEntry          CtvHierarchy[]       @relation("Ctv")
  transactions        Transaction[]        @relation("CtvTransactions")
  customers           Customer[]           @relation("CtvCustomers")
  kpiLogs             KpiLog[]
  rankHistory         RankHistory[]
  ownedAgency         Agency?              @relation("AgencyOwner")
  promotionEligibility PromotionEligibility[]
  teamBonuses         TeamBonus[]
  businessHousehold   BusinessHousehold?
  trainerContracts    B2BContract[]        @relation("Trainer")
  traineeContracts    B2BContract[]        @relation("Trainee")
  trainerLogs         TrainingLog[]        @relation("TrainerLogs")
  traineeLogs         TrainingLog[]        @relation("TraineeLogs")
  invoicesFrom        Invoice[]            @relation("InvoicesFrom")
  invoicesTo          Invoice[]            @relation("InvoicesTo")
  transfersFrom       AutoTransferLog[]    @relation("TransfersFrom")
  transfersTo         AutoTransferLog[]    @relation("TransfersTo")
  taxRecords          TaxRecord[]

  // C12.4: Management fees (F1/F2/F3) + breakaway fees (2-phase)
  mgmtFeesFrom        ManagementFee[]      @relation("MgmtFeeFrom")
  mgmtFeesTo          ManagementFee[]      @relation("MgmtFeeTo")
  breakawayLog        BreakawayLog?        @relation("BreakawayUser")
  breakawayOldParent  BreakawayLog[]       @relation("BreakawayOldParent")
  breakawayNewParent  BreakawayLog[]       @relation("BreakawayNewParent")
  breakawayFeesFrom   BreakawayFee[]       @relation("BreakFeeFrom")
  breakawayFeesTo     BreakawayFee[]       @relation("BreakFeeTo")

  // Notifications
  notifications       Notification[]

  // Cash deposits (CTV batches cash collections)
  cashDeposits        CashDeposit[] @relation("CashDepositCtv")

  // Member capability (1-1): wallet, points, referrals
  memberWallet        MemberWallet?
  referralsGiven      ReferralLog[] @relation("ReferrerUser")
  referralsReceived   ReferralLog[] @relation("RefereeUser")

  @@map("users")
}

model CtvHierarchy {
  id          Int      @id @default(autoincrement())
  ctvId       Int      @map("ctv_id")
  managerId   Int      @map("manager_id")
  level       String   // direct, level2, level3
  appointedAt DateTime @default(now()) @map("appointed_at")

  ctv         User     @relation("Ctv", fields: [ctvId], references: [id])
  manager     User     @relation("Manager", fields: [managerId], references: [id])

  @@map("ctv_hierarchy")
}

model Agency {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  name            String
  depositAmount   Float    @map("deposit_amount")
  depositTier     String   @map("deposit_tier") // 50tr, 100tr, 300tr
  address         String?

  user            User     @relation("AgencyOwner", fields: [userId], references: [id])
  users           User[]   @relation("AgencyUser")
  transactions    Transaction[] @relation("AgencyTransactions")
  customers       Customer[]    @relation("AgencyCustomers")
  inventoryWarnings InventoryWarning[]

  @@map("agencies")
}

model CommissionConfig {
  id            Int     @id @default(autoincrement())
  tier          String  @unique // CTV, PP, TP, GDV, GDKD
  selfSalePct   Float   @map("self_sale_pct")
  fixedSalary   Float   @map("fixed_salary")
  isSoftSalary  Boolean @default(true) @map("is_soft_salary")

  @@map("commission_config")
}

model AgencyCommissionConfig {
  id            Int    @id @default(autoincrement())
  group         String @unique // A, B, C
  commissionPct Float  @map("commission_pct")
  bonusPct      Float  @map("bonus_pct")

  @@map("agency_commission_config")
}

model FeeConfig {
  id          Int      @id @default(autoincrement())
  tier        String   @unique // M0, M1, M2, M3, M4, M5
  minCombo    Int      @map("min_combo")
  maxCombo    Int?     @map("max_combo")
  feeAmount   Float    @map("fee_amount")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("fee_config")
}

model BusinessHousehold {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  businessName    String   @map("business_name")
  taxCode         String?  @map("tax_code")
  businessLicense String?  @map("business_license")
  registeredAt    DateTime @default(now()) @map("registered_at")
  status          String   @default("active") // active, suspended, terminated

  // Contract info (V13.1 Mục 5.3)
  dealerContractNo   String?   @map("dealer_contract_no")
  dealerSignedAt     DateTime? @map("dealer_signed_at")
  dealerExpiredAt    DateTime? @map("dealer_expired_at")
  dealerTermMonths   Int?      @default(12) @map("dealer_term_months")
  dealerPdfUrl       String?   @map("dealer_pdf_url")

  trainingContractNo   String?   @map("training_contract_no")
  trainingSignedAt     DateTime? @map("training_signed_at")
  trainingExpiredAt    DateTime? @map("training_expired_at")
  trainingTermMonths   Int?      @default(12) @map("training_term_months")
  trainingPdfUrl       String?   @map("training_pdf_url")

  // Bank info for training-fee disbursement
  bankName           String?   @map("bank_name")
  bankAccountNo      String?   @map("bank_account_no")
  bankAccountHolder  String?   @map("bank_account_holder")

  // Optional: marker for business-line registered "đào tạo" (tư vấn đào tạo)
  trainingLineRegistered Boolean @default(false) @map("training_line_registered")

  user            User     @relation(fields: [userId], references: [id])

  @@map("business_households")
}

model B2BContract {
  id                  Int       @id @default(autoincrement())
  contractNo          String    @unique @map("contract_no")
  trainerId           Int       @map("trainer_id")
  traineeId           Int       @map("trainee_id")
  signedAt            DateTime  @default(now()) @map("signed_at")
  expiredAt           DateTime? @map("expired_at")
  status              String    @default("active") // active, expired, terminated
  terminatedAt        DateTime? @map("terminated_at")
  terminationReason   String?   @map("termination_reason")
  terminatedBy        Int?      @map("terminated_by") // V12.2: who terminated

  trainer             User      @relation("Trainer", fields: [trainerId], references: [id])
  trainee             User      @relation("Trainee", fields: [traineeId], references: [id])
  invoices            Invoice[]

  @@map("b2b_contracts")
}

model TrainingLog {
  id              Int       @id @default(autoincrement())
  trainerId       Int       @map("trainer_id")
  traineeId       Int       @map("trainee_id")
  sessionDate     DateTime  @map("session_date")
  durationMinutes Int       @map("duration_minutes")
  content         String
  menteeConfirmed Boolean   @default(false) @map("mentee_confirmed")
  mentorConfirmed Boolean   @default(true) @map("mentor_confirmed")
  status          String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  verifiedBy      Int?      @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // V12.2: OTP confirmation
  otpCode         String?   @map("otp_code")
  otpExpiresAt    DateTime? @map("otp_expires_at")

  // C12.3: Failover / OTP fallback
  otpSentAt       DateTime? @map("otp_sent_at")
  otpSentMethod   String?   @map("otp_sent_method") // SMS, EMAIL, MANUAL
  otpRetryCount   Int       @default(0) @map("otp_retry_count")
  otpFailCount    Int       @default(0) @map("otp_fail_count")
  otpBlockedUntil DateTime? @map("otp_blocked_until")
  adminVerified   Boolean   @default(false) @map("admin_verified")
  adminVerifiedBy Int?      @map("admin_verified_by")
  adminVerifiedAt DateTime? @map("admin_verified_at")

  trainer         User      @relation("TrainerLogs", fields: [trainerId], references: [id])
  trainee         User      @relation("TraineeLogs", fields: [traineeId], references: [id])

  @@map("training_logs")
}

// V12.2: Electronic invoice for training service fees
model Invoice {
  id            Int      @id @default(autoincrement())
  contractId    Int?     @map("contract_id")
  fromUserId    Int      @map("from_user_id")
  toUserId      Int      @map("to_user_id")
  amount        Float
  feeTier       String   @map("fee_tier") // M0-M5
  invoiceNumber String   @unique @map("invoice_number")
  issuedAt      DateTime @default(now()) @map("issued_at")
  pdfUrl        String?  @map("pdf_url")
  status        String   @default("DRAFT") // DRAFT/SENT/PAID/CANCELLED/PENDING_MANUAL_INVOICE

  // C12.3: Failover / manual invoice issuance
  externalId     String?   @map("external_id")
  retryCount     Int       @default(0) @map("retry_count")
  lastRetryAt    DateTime? @map("last_retry_at")
  manualIssued   Boolean   @default(false) @map("manual_issued")
  issuedBy       Int?      @map("issued_by")
  issuedAtManual DateTime? @map("issued_at_manual")

  contract      B2BContract? @relation(fields: [contractId], references: [id])
  fromUser      User         @relation("InvoicesFrom", fields: [fromUserId], references: [id])
  toUser        User         @relation("InvoicesTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@map("invoices")
}

// V12.2: Auto-transfer log for monthly fee settlement
model AutoTransferLog {
  id           Int      @id @default(autoincrement())
  fromUserId   Int      @map("from_user_id")
  toUserId     Int      @map("to_user_id")
  amount       Float
  transferDate DateTime @default(now()) @map("transfer_date")
  reference    Int?     // invoiceId
  status       String   @default("PENDING") // PENDING/SUCCESS/FAILED/FAILED_PERMANENT/MANUAL_RESOLVED
  errorMessage String?  @map("error_message")

  // C12.3: Failover / retry tracking
  retryCount     Int       @default(0) @map("retry_count")
  maxRetry       Int       @default(3) @map("max_retry")
  lastRetryAt    DateTime? @map("last_retry_at")
  manualResolved Boolean   @default(false) @map("manual_resolved")
  resolvedBy     Int?      @map("resolved_by")
  resolvedAt     DateTime? @map("resolved_at")
  adminNote      String?   @map("admin_note")

  fromUser     User     @relation("TransfersFrom", fields: [fromUserId], references: [id])
  toUser       User     @relation("TransfersTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([status])
  @@map("auto_transfer_logs")
}

// C12.3: Admin manual action audit log
model AdminManualAction {
  id          Int      @id @default(autoincrement())
  adminId     Int      @map("admin_id")
  actionType  String   @map("action_type") // VERIFY_TRAINING, MARK_TRANSFER_SUCCESS, MARK_TRANSFER_FAILED, VERIFY_KYC, ISSUE_INVOICE, RESEND_OTP
  targetType  String   @map("target_type") // TrainingLog, AutoTransferLog, User, Invoice
  targetId    Int      @map("target_id")
  oldStatus   String?  @map("old_status")
  newStatus   String?  @map("new_status")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([actionType])
  @@index([targetType, targetId])
  @@map("admin_manual_actions")
}

// V12.2: Personal Income Tax (TNCN) record
model TaxRecord {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  month          String   // YYYY-MM
  taxableIncome  Float    @map("taxable_income")
  taxAmount      Float    @map("tax_amount") // 10% TNCN
  status         String   @default("PENDING") // PENDING/PAID
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@map("tax_records")
}

model Product {
  id       Int    @id @default(autoincrement())
  name     String
  category String // NS, TPCN, FMCG, GiaVi, CheBien, TienLoi
  price    Float
  cogsPct  Float  @map("cogs_pct")
  unit     String

  transactionItems TransactionItem[]
  inventoryWarnings InventoryWarning[]

  @@map("products")
}

model Transaction {
  id              Int      @id @default(autoincrement())
  kiotvietOrderId String?  @map("kiotviet_order_id")
  customerId      Int?     @map("customer_id")
  ctvId           Int?     @map("ctv_id")
  agencyId        Int?     @map("agency_id")
  channel         String   // ctv, agency, showroom
  totalAmount     Float    @map("total_amount")
  cogsAmount      Float    @map("cogs_amount")
  createdAt       DateTime @default(now()) @map("created_at")

  // Reconciliation fields
  status          String   @default("CONFIRMED") // PENDING/CONFIRMED/REJECTED
  paymentMethod   String?  @map("payment_method") // bank_transfer/cash/momo/zalopay
  bankCode        String?  @map("bank_code")
  qrCodeData      String?  @map("qr_code_data")
  ctvSubmittedAt  DateTime? @map("ctv_submitted_at")
  confirmedBy     Int?     @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  rejectedReason  String?  @map("rejected_reason")
  cashDepositId   Int?     @map("cash_deposit_id")

  customer        Customer?  @relation(fields: [customerId], references: [id])
  ctv             User?      @relation("CtvTransactions", fields: [ctvId], references: [id])
  agency          Agency?    @relation("AgencyTransactions", fields: [agencyId], references: [id])
  items           TransactionItem[]
  paymentProof    PaymentProof?
  cashDeposit     CashDeposit? @relation(fields: [cashDepositId], references: [id])

  @@index([status, channel])
  @@index([ctvId, status])
  @@map("transactions")
}

model PaymentProof {
  id            Int      @id @default(autoincrement())
  transactionId Int      @unique @map("transaction_id")
  imageUrl      String   @map("image_url")
  notes         String?
  uploadedBy    Int      @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("payment_proofs")
}

model CashDeposit {
  id              Int      @id @default(autoincrement())
  ctvId           Int      @map("ctv_id")
  amount          Float
  transactionIds  String   @map("transaction_ids") // JSON string of int array
  status          String   @default("PENDING") // PENDING/CONFIRMED/REJECTED
  depositedAt     DateTime @default(now()) @map("deposited_at")
  confirmedBy     Int?     @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  notes           String?

  ctv             User     @relation("CashDepositCtv", fields: [ctvId], references: [id])
  transactions    Transaction[]

  @@index([status])
  @@index([ctvId, status])
  @@map("cash_deposits")
}

model TransactionItem {
  id            Int    @id @default(autoincrement())
  transactionId Int    @map("transaction_id")
  productId     Int    @map("product_id")
  quantity      Int
  unitPrice     Float  @map("unit_price")
  totalPrice    Float  @map("total_price")

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  ctvId         Int?     @map("ctv_id")
  agencyId      Int?     @map("agency_id")
  firstPurchase DateTime? @map("first_purchase")
  totalSpent    Float    @default(0) @map("total_spent")

  ctv           User?    @relation("CtvCustomers", fields: [ctvId], references: [id])
  agency        Agency?  @relation("AgencyCustomers", fields: [agencyId], references: [id])
  transactions  Transaction[]

  @@map("customers")
}

model KpiLog {
  id            Int    @id @default(autoincrement())
  ctvId         Int    @map("ctv_id")
  month         String // YYYY-MM
  selfSales     Int    @map("self_sales") // number of combos
  portfolioSize Int    @map("portfolio_size")
  rankBefore    String @map("rank_before")
  rankAfter     String @map("rank_after")

  ctv           User   @relation(fields: [ctvId], references: [id])

  @@map("kpi_logs")
}

model RankHistory {
  id        Int      @id @default(autoincrement())
  ctvId     Int      @map("ctv_id")
  oldRank   String   @map("old_rank")
  newRank   String   @map("new_rank")
  reason    String
  changedAt DateTime @default(now()) @map("changed_at")
  changedBy String   @map("changed_by")

  ctv       User     @relation(fields: [ctvId], references: [id])

  @@map("rank_history")
}

// T+1 promotion: promotion takes effect next month, not immediately
model PromotionEligibility {
  id              Int      @id @default(autoincrement())
  ctvId           Int      @map("ctv_id")
  currentRank     String   @map("current_rank")
  targetRank      String   @map("target_rank")
  effectiveMonth  String   @map("effective_month") // YYYY-MM (T+1, next month)
  metAt           DateTime @default(now()) @map("met_at")
  status          String   @default("pending") // pending, approved, rejected

  ctv             User     @relation(fields: [ctvId], references: [id])

  @@map("promotion_eligibility")
}

// Team bonus: additional bonus when team revenue exceeds thresholds
model TeamBonus {
  id          Int      @id @default(autoincrement())
  ctvId       Int      @map("ctv_id")
  month       String   // YYYY-MM
  teamRevenue Float    @map("team_revenue")
  bonusAmount Float    @map("bonus_amount")
  tier        String   // bronze, silver, gold (based on team revenue threshold)
  createdAt   DateTime @default(now()) @map("created_at")

  ctv         User     @relation(fields: [ctvId], references: [id])

  @@map("team_bonuses")
}

model InventoryWarning {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  agencyId    Int?     @map("agency_id")
  quantity    Int
  expiryDate  DateTime @map("expiry_date")
  warningType String   @map("warning_type") // low_stock, expiring_soon, expired
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id])
  agency      Agency?  @relation(fields: [agencyId], references: [id])

  @@map("inventory_warnings")
}

// =======================================================================
// C12.4: Phí quản lý trong nhóm + Phí sau thoát ly (2 giai đoạn)
// Nguyên tắc: TẤT CẢ khoản thù lao/HH/phí đều do CCB Mart chi trả từ
// doanh thu bán hàng, không có chuyển tiền trực tiếp giữa đối tác.
// =======================================================================

// Phí quản lý trong nhóm - điều kiện: cấp trên phải có >=20h đào tạo/tháng
// F1 (10%) -> TP+ trên combo bán lẻ trực tiếp của F1
// F2 (5%)  -> GĐV+ trên combo bán lẻ trực tiếp của F2
// F3 (3%)  -> GĐKD trên combo bán lẻ trực tiếp của F3
model ManagementFee {
  id         Int      @id @default(autoincrement())
  fromUserId Int      @map("from_user_id") // cấp dưới tạo doanh số
  toUserId   Int      @map("to_user_id")   // cấp trên nhận phí
  level      Int      // 1 (F1), 2 (F2), 3 (F3)
  amount     Float
  month      String   // YYYY-MM
  status     String   @default("PENDING") // PENDING/PAID
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser   User     @relation("MgmtFeeFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("MgmtFeeTo",   fields: [toUserId],   references: [id])

  @@index([toUserId, month])
  @@index([fromUserId, month])
  @@map("management_fees")
}

// Log mỗi lần mentee thoát ly khỏi mentor cũ
// Khi thoát ly: parentId được chuyển lên grandParent (cấp trên của mentor cũ)
// Active trong 12 tháng để tính phí giai đoạn 1
model BreakawayLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id") // user thoát ly (1 user = 1 breakaway active)
  oldParentId  Int      @map("old_parent_id")   // mentor cũ (F1 cũ)
  newParentId  Int      @map("new_parent_id")   // grandParent (F2 cũ đã thành cấp trên trực tiếp)
  breakawayAt  DateTime @default(now()) @map("breakaway_at")
  expireAt     DateTime @map("expire_at")       // +12 months
  status       String   @default("ACTIVE")      // ACTIVE/EXPIRED

  user         User         @relation("BreakawayUser",      fields: [userId],       references: [id])
  oldParent    User         @relation("BreakawayOldParent", fields: [oldParentId],  references: [id])
  newParent    User         @relation("BreakawayNewParent", fields: [newParentId],  references: [id])
  breakawayFees BreakawayFee[]

  @@index([status, expireAt])
  @@index([oldParentId])
  @@index([newParentId])
  @@index([status])
  @@map("breakaway_logs")
}

// Phí giai đoạn 1 sau thoát ly (12 tháng đầu)
// Level 1 = 3% cho F1 cũ trên toàn doanh số nhánh thoát
// Level 2 = 2% cho F2 cũ trên toàn doanh số nhánh thoát
// Level 3 = 1% cho GĐKD CHỈ KHI GĐKD không phải F1/F2 cũ (CCB Mart trả từ quỹ)
model BreakawayFee {
  id             Int      @id @default(autoincrement())
  breakawayLogId Int      @map("breakaway_log_id")
  fromUserId     Int      @map("from_user_id") // user thoát ly
  toUserId       Int      @map("to_user_id")   // mentor cũ hoặc GĐKD nhận 1%
  level          Int      // 1 (3%), 2 (2%), 3 (1% cho GĐKD)
  amount         Float
  month          String   // YYYY-MM
  status         String   @default("PENDING") // PENDING/PAID
  createdAt      DateTime @default(now()) @map("created_at")

  breakawayLog   BreakawayLog @relation(fields: [breakawayLogId], references: [id])
  fromUser       User         @relation("BreakFeeFrom", fields: [fromUserId], references: [id])
  toUser         User         @relation("BreakFeeTo",   fields: [toUserId],   references: [id])

  @@index([toUserId, month])
  @@index([breakawayLogId, month])
  @@map("breakaway_fees")
}

model SyncLog {
  id            Int      @id @default(autoincrement())
  source        String
  recordsSynced Int      @map("records_synced")
  syncedAt      DateTime @default(now()) @map("synced_at")
  status        String

  @@map("sync_logs")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   // SALARY_WARNING, RANK_CHANGE, TRANSACTION_CONFIRMED, etc.
  title     String
  content   String
  metadata  String?  // JSON-encoded
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ========================================================
// Member system (V13.1): 1 user có thể vừa là CTV vừa Member
// User.isMember = true ↔ có MemberWallet (1-1 via userId)
// ========================================================

model MembershipTier {
  id                 Int      @id @default(autoincrement())
  name               String   @unique // GREEN/BASIC/STANDARD/VIP_GOLD (V13.3: 4 hạng)
  minDeposit         Float    @map("min_deposit")
  pointsRate         Float    @default(0.01) @map("points_rate") // % của đơn mua tính thành điểm
  discountPct        Float    @default(0) @map("discount_pct") // % giảm giá khi mua hàng
  referralPct        Float    @default(0) @map("referral_pct") // % hoa hồng giới thiệu
  monthlyReferralCap Float    @default(2000000) @map("monthly_referral_cap") // V13.3: cap 2tr/tháng
  color              String?  // cho UI badge
  description        String?

  wallets     MemberWallet[]

  @@map("membership_tiers")
}

model MemberWallet {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  tierId                Int?     @map("tier_id")
  balance               Float    @default(0)      // V13.3: tổng số dư (availableBalance + reserveBalance)
  availableBalance      Float    @default(0) @map("available_balance") // V13.3: 70% khả dụng
  reserveBalance        Float    @default(0) @map("reserve_balance")   // V13.3: 30% khóa thanh khoản
  points                Int      @default(0)       // điểm tích luỹ
  referralCode          String   @unique @map("referral_code") // CCB_XXXXXX
  referredById          Int?     @map("referred_by_id") // wallet của người giới thiệu
  totalDeposited        Float    @default(0) @map("total_deposited")
  totalSpent            Float    @default(0) @map("total_spent")
  referralCap           Float    @default(2000000) @map("referral_cap") // V13.3: cap 2tr/tháng
  referralEarned        Float    @default(0) @map("referral_earned")
  monthlyReferralEarned Float    @default(0) @map("monthly_referral_earned")
  createdAt             DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id])
  tier           MembershipTier? @relation(fields: [tierId], references: [id])
  deposits       DepositHistory[]
  referrals      MemberWallet[]  @relation("WalletReferral")
  referredBy     MemberWallet?   @relation("WalletReferral", fields: [referredById], references: [id])
  earnedCommissions    ReferralCommission[] @relation("EarnerWallet")
  sourcedCommissions   ReferralCommission[] @relation("SourceWallet")

  @@index([referralCode])
  @@map("member_wallets")
}

// V13.1+: Commission log when a referral deposit is confirmed
model ReferralCommission {
  id              Int      @id @default(autoincrement())
  earnerWalletId  Int      @map("earner_wallet_id")
  sourceWalletId  Int      @map("source_wallet_id")
  amount          Float
  ratePct         Float    @map("rate_pct")
  month           String   // YYYY-MM
  createdAt       DateTime @default(now()) @map("created_at")

  earnerWallet    MemberWallet @relation("EarnerWallet", fields: [earnerWalletId], references: [id])
  sourceWallet    MemberWallet @relation("SourceWallet", fields: [sourceWalletId], references: [id])

  @@index([earnerWalletId, month])
  @@map("referral_commissions")
}

model DepositHistory {
  id          Int      @id @default(autoincrement())
  walletId    Int      @map("wallet_id")
  amount      Float
  method      String   // bank_transfer / cash / momo / zalopay
  status      String   @default("PENDING") // PENDING/CONFIRMED/REJECTED
  reference   String?  // mã giao dịch từ cổng thanh toán
  notes       String?
  confirmedBy Int?     @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  wallet      MemberWallet @relation(fields: [walletId], references: [id])

  @@index([walletId, status])
  @@map("deposit_history")
}

model ReferralLog {
  id          Int      @id @default(autoincrement())
  referrerId  Int      @map("referrer_id") // user id của người giới thiệu
  refereeId   Int      @map("referee_id")  // user id của người được giới thiệu
  month       String   // YYYY-MM
  bonusAmount Float    @map("bonus_amount")
  sourceTxnId Int?     @map("source_txn_id") // giao dịch nào gây ra bonus
  sunsetAt    DateTime @map("sunset_at")      // hết hiệu lực sau 12 tháng
  createdAt   DateTime @default(now()) @map("created_at")

  referrer    User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referee     User     @relation("RefereeUser",  fields: [refereeId],  references: [id])

  @@index([referrerId, month])
  @@index([refereeId])
  @@map("referral_logs")
}
