generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   // ctv, agency, admin
  name          String
  phone         String?
  rank          String?  // CTV, PP, TP, GDV, GDKD
  parentId      Int?     @map("parent_id")
  agencyId      Int?     @map("agency_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  isBusinessHousehold Boolean @default(false) @map("is_business_household")

  // V12.2 + V13.3: eKYC
  kycStatus       String    @default("PENDING") @map("kyc_status")
  kycSubmittedAt  DateTime? @map("kyc_submitted_at")
  kycVerifiedAt   DateTime? @map("kyc_verified_at")
  kycRejectReason String?   @map("kyc_reject_reason")
  idNumber        String?   @unique @map("id_number")
  idFrontImage    String?   @map("id_front_image")
  idBackImage     String?   @map("id_back_image")
  kycMethod       String    @default("AUTO") @map("kyc_method")
  kycManualNote   String?   @map("kyc_manual_note")
  kycVerifiedBy   Int?      @map("kyc_verified_by")
  kycDeviceId     String?   @map("kyc_device_id")
  kycIpAddress    String?   @map("kyc_ip_address")

  parent        User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children      User[]   @relation("UserHierarchy")
  agency        Agency?  @relation("AgencyUser", fields: [agencyId], references: [id])

  managedCtvs   CtvHierarchy[] @relation("Manager")
  asCtvEntry    CtvHierarchy[] @relation("Ctv")
  transactions  Transaction[]  @relation("CtvTransactions")
  customers     Customer[]     @relation("CtvCustomers")
  kpiLogs       KpiLog[]
  rankHistory   RankHistory[]
  ownedAgency   Agency?        @relation("AgencyOwner")
  notifications Notification[]
  cashDeposits        CashDeposit[] @relation("CtvDeposits")
  confirmedDeposits   CashDeposit[] @relation("AdminConfirmedDeposits")
  memberWallet        MemberWallet? @relation("MemberWallet")
  pushSubscriptions   PushSubscription[]
  importLogs          ImportLog[]
  promotionEligibilities PromotionEligibility[] @relation("CtvPromotions")
  teamBonuses         TeamBonus[]    @relation("CtvTeamBonuses")
  loyaltyPoints       LoyaltyPoint[] @relation("UserLoyaltyPoints")
  professionalTitle   ProfessionalTitle?

  // V13 restored relations
  businessHousehold   BusinessHousehold?
  trainerContracts    B2BContract[]        @relation("Trainer")
  traineeContracts    B2BContract[]        @relation("Trainee")
  trainerLogs         TrainingLog[]        @relation("TrainerLogs")
  traineeLogs         TrainingLog[]        @relation("TraineeLogs")
  invoicesFrom        Invoice[]            @relation("InvoicesFrom")
  invoicesTo          Invoice[]            @relation("InvoicesTo")
  transfersFrom       AutoTransferLog[]    @relation("TransfersFrom")
  transfersTo         AutoTransferLog[]    @relation("TransfersTo")
  taxRecords          TaxRecord[]
  mgmtFeesFrom        ManagementFee[]      @relation("MgmtFeeFrom")
  mgmtFeesTo          ManagementFee[]      @relation("MgmtFeeTo")
  breakawayLog        BreakawayLog?        @relation("BreakawayUser")
  breakawayOldParent  BreakawayLog[]       @relation("BreakawayOldParent")
  breakawayNewParent  BreakawayLog[]       @relation("BreakawayNewParent")
  breakawayFeesFrom   BreakawayFee[]       @relation("BreakFeeFrom")
  breakawayFeesTo     BreakawayFee[]       @relation("BreakFeeTo")
  auditLogs           AuditLog[]           @relation("AuditLogs")

  @@index([parentId])
  @@index([rank])
  @@index([role])
  @@index([role, isActive])
  @@map("users")
}

model CtvHierarchy {
  id          Int      @id @default(autoincrement())
  ctvId       Int      @map("ctv_id")
  managerId   Int      @map("manager_id")
  level       String   // DIRECT, INDIRECT2, INDIRECT3
  appointedAt DateTime @default(now()) @map("appointed_at")

  ctv         User     @relation("Ctv", fields: [ctvId], references: [id])
  manager     User     @relation("Manager", fields: [managerId], references: [id])

  @@map("ctv_hierarchy")
}

model Agency {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  name            String
  depositAmount   Decimal  @db.Decimal(15, 0) @map("deposit_amount")
  depositTier     String   @map("deposit_tier")
  address         String?

  user            User     @relation("AgencyOwner", fields: [userId], references: [id])
  users           User[]   @relation("AgencyUser")
  transactions    Transaction[] @relation("AgencyTransactions")
  customers       Customer[]    @relation("AgencyCustomers")
  inventoryWarnings InventoryWarning[]

  @@map("agencies")
}

model CommissionConfig {
  id            Int     @id @default(autoincrement())
  tier          String  @unique
  selfSalePct   Decimal @db.Decimal(5, 4) @map("self_sale_pct")
  directPct     Decimal @db.Decimal(5, 4) @map("direct_pct")
  indirect2Pct  Decimal @db.Decimal(5, 4) @map("indirect2_pct")
  indirect3Pct  Decimal @db.Decimal(5, 4) @map("indirect3_pct")
  fixedSalary   Decimal @db.Decimal(15, 0) @map("fixed_salary")

  @@map("commission_config")
}

model AgencyCommissionConfig {
  id            Int     @id @default(autoincrement())
  group         String  @unique
  commissionPct Decimal @db.Decimal(5, 4) @map("commission_pct")
  bonusPct      Decimal @db.Decimal(5, 4) @map("bonus_pct")

  @@map("agency_commission_config")
}

model Product {
  id       Int     @id @default(autoincrement())
  name     String
  category String
  price    Decimal @db.Decimal(15, 0)
  cogsPct  Decimal @db.Decimal(5, 4) @map("cogs_pct")
  unit     String

  transactionItems TransactionItem[]
  inventoryWarnings InventoryWarning[]

  @@map("products")
}

model Transaction {
  id              Int      @id @default(autoincrement())
  kiotvietOrderId String?  @map("kiotviet_order_id")
  customerId      Int?     @map("customer_id")
  ctvId           Int?     @map("ctv_id")
  agencyId        Int?     @map("agency_id")
  channel         String   // ctv, agency, showroom
  totalAmount     Decimal  @db.Decimal(15, 0) @map("total_amount")
  cogsAmount      Decimal  @db.Decimal(15, 0) @map("cogs_amount")
  status          String   @default("CONFIRMED") // PENDING, CONFIRMED, REJECTED
  paymentMethod   String?  @map("payment_method") // bank_transfer, cash
  bankCode        String?  @map("bank_code") // last 4 digits
  qrCodeData      String?  @map("qr_code_data")
  bankReference   String?  @map("bank_reference")
  ctvSubmittedAt  DateTime? @map("ctv_submitted_at")
  confirmedBy     Int?     @map("confirmed_by")
  confirmedAt     DateTime? @map("confirmed_at")
  rejectedReason  String?  @map("rejected_reason")
  cashDepositId   Int?     @map("cash_deposit_id")
  createdAt       DateTime @default(now()) @map("created_at")

  customer        Customer?    @relation(fields: [customerId], references: [id])
  ctv             User?        @relation("CtvTransactions", fields: [ctvId], references: [id])
  agency          Agency?      @relation("AgencyTransactions", fields: [agencyId], references: [id])
  items           TransactionItem[]
  paymentProof    PaymentProof?
  cashDeposit     CashDeposit? @relation(fields: [cashDepositId], references: [id])

  @@index([ctvId])
  @@index([agencyId])
  @@index([channel])
  @@index([createdAt])
  @@index([status])
  @@index([ctvId, status])
  @@index([ctvId, createdAt])
  @@index([agencyId, createdAt])
  @@index([channel, createdAt])
  @@map("transactions")
}

model TransactionItem {
  id            Int     @id @default(autoincrement())
  transactionId Int     @map("transaction_id")
  productId     Int     @map("product_id")
  quantity      Int
  unitPrice     Decimal @db.Decimal(15, 0) @map("unit_price")
  totalPrice    Decimal @db.Decimal(15, 0) @map("total_price")

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  ctvId         Int?     @map("ctv_id")
  agencyId      Int?     @map("agency_id")
  firstPurchase DateTime? @map("first_purchase")
  totalSpent    Decimal  @db.Decimal(15, 0) @default(0) @map("total_spent")

  ctv           User?    @relation("CtvCustomers", fields: [ctvId], references: [id])
  agency        Agency?  @relation("AgencyCustomers", fields: [agencyId], references: [id])
  transactions  Transaction[]
  memberWallet  MemberWallet?

  @@map("customers")
}

model KpiLog {
  id            Int    @id @default(autoincrement())
  ctvId         Int    @map("ctv_id")
  month         String
  selfSales     Int    @map("self_sales")
  portfolioSize Int    @map("portfolio_size")
  rankBefore    String @map("rank_before")
  rankAfter     String @map("rank_after")

  ctv           User   @relation(fields: [ctvId], references: [id])

  @@unique([ctvId, month])
  @@index([month])
  @@map("kpi_logs")
}

model RankHistory {
  id        Int      @id @default(autoincrement())
  ctvId     Int      @map("ctv_id")
  oldRank   String   @map("old_rank")
  newRank   String   @map("new_rank")
  reason    String
  changedAt DateTime @default(now()) @map("changed_at")
  changedBy String   @map("changed_by")

  ctv       User     @relation(fields: [ctvId], references: [id])

  @@map("rank_history")
}

model InventoryWarning {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  agencyId    Int?     @map("agency_id")
  quantity    Int
  expiryDate  DateTime @map("expiry_date")
  warningType String   @map("warning_type")
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id])
  agency      Agency?  @relation(fields: [agencyId], references: [id])

  @@map("inventory_warnings")
}

model SyncLog {
  id            Int      @id @default(autoincrement())
  source        String
  recordsSynced Int      @map("records_synced")
  syncedAt      DateTime @default(now()) @map("synced_at")
  status        String

  @@map("sync_logs")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  title     String
  content   String   @db.Text
  metadata  String?  @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model PaymentProof {
  id            Int      @id @default(autoincrement())
  transactionId Int      @unique @map("transaction_id")
  imageUrl      String   @map("image_url")
  uploadedBy    Int      @map("uploaded_by")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")
  notes         String?

  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("payment_proofs")
}

model CashDeposit {
  id             Int       @id @default(autoincrement())
  ctvId          Int       @map("ctv_id")
  amount         Decimal   @db.Decimal(15, 0)
  transactionIds String    @db.Text @map("transaction_ids") // JSON array
  depositedAt    DateTime  @default(now()) @map("deposited_at")
  confirmedBy    Int?      @map("confirmed_by")
  confirmedAt    DateTime? @map("confirmed_at")
  status         String    @default("PENDING") // PENDING, CONFIRMED, REJECTED
  notes          String?

  ctv            User      @relation("CtvDeposits", fields: [ctvId], references: [id])
  confirmAdmin   User?     @relation("AdminConfirmedDeposits", fields: [confirmedBy], references: [id])
  transactions   Transaction[]

  @@index([ctvId])
  @@index([status])
  @@map("cash_deposits")
}

model KpiConfig {
  id              Int    @id @default(autoincrement())
  rank            String @unique
  minSelfCombo    Int    @map("min_self_combo")
  minPortfolio    Int    @map("min_portfolio")
  fallbackRank    String @map("fallback_rank")

  @@map("kpi_config")
}

model CogsConfig {
  id          Int     @id @default(autoincrement())
  phase       String  @unique
  name        String
  cogsPct     Decimal @db.Decimal(5, 4) @map("cogs_pct")
  description String?

  @@map("cogs_config")
}

model MembershipTier {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  minDeposit         Decimal  @db.Decimal(15, 0) @map("min_deposit")
  discountPct        Decimal  @db.Decimal(5, 4) @map("discount_pct")
  referralPct        Decimal  @db.Decimal(5, 4) @map("referral_pct")
  monthlyReferralCap Decimal  @db.Decimal(15, 0) @map("monthly_referral_cap")
  color              String   @default("gray")
  createdAt          DateTime @default(now()) @map("created_at")

  wallets            MemberWallet[]

  @@map("membership_tiers")
}

model MemberWallet {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  customerId            Int?     @unique @map("customer_id")
  tierId                Int      @map("tier_id")
  balance               Decimal  @db.Decimal(15, 0) @default(0)
  totalDeposit          Decimal  @db.Decimal(15, 0) @default(0) @map("total_deposit")
  referralCode          String   @unique @map("referral_code")
  referredById          Int?     @map("referred_by_id")
  referralEarned        Decimal  @db.Decimal(15, 0) @default(0) @map("referral_earned")
  monthlyReferralEarned Decimal  @db.Decimal(15, 0) @default(0) @map("monthly_referral_earned")
  createdAt             DateTime @default(now()) @map("created_at")

  user                  User              @relation("MemberWallet", fields: [userId], references: [id])
  customer              Customer?         @relation(fields: [customerId], references: [id])
  tier                  MembershipTier    @relation(fields: [tierId], references: [id])
  referredBy            MemberWallet?     @relation("Referrals", fields: [referredById], references: [id])
  referrals             MemberWallet[]    @relation("Referrals")
  deposits              DepositHistory[]
  commissionsEarned     ReferralCommission[] @relation("CommissionEarner")
  commissionsGenerated  ReferralCommission[] @relation("CommissionGenerator")

  @@index([referralCode])
  @@index([tierId])
  @@map("member_wallets")
}

model DepositHistory {
  id          Int       @id @default(autoincrement())
  walletId    Int       @map("wallet_id")
  amount      Decimal   @db.Decimal(15, 0)
  method      String    // bank_transfer, cash, momo, zalopay
  status      String    @default("PENDING")
  provider    String?   // momo, zalopay
  providerTxId String?  @map("provider_tx_id")
  confirmedBy Int?      @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  wallet      MemberWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@map("deposit_history")
}

model ReferralCommission {
  id              Int      @id @default(autoincrement())
  earnerWalletId  Int      @map("earner_wallet_id")
  sourceWalletId  Int      @map("source_wallet_id")
  amount          Decimal  @db.Decimal(15, 0)
  ratePct         Decimal  @db.Decimal(5, 4) @map("rate_pct")
  month           String
  createdAt       DateTime @default(now()) @map("created_at")

  earnerWallet    MemberWallet @relation("CommissionEarner", fields: [earnerWalletId], references: [id])
  sourceWallet    MemberWallet @relation("CommissionGenerator", fields: [sourceWalletId], references: [id])

  @@index([earnerWalletId])
  @@index([month])
  @@map("referral_commissions")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("push_subscriptions")
}

model ImportLog {
  id          Int      @id @default(autoincrement())
  type        String   // ctv, product, agency, member
  fileName    String   @map("file_name")
  totalRows   Int      @map("total_rows")
  successRows Int      @map("success_rows")
  failedRows  Int      @map("failed_rows")
  importedBy  Int      @map("imported_by")
  importedAt  DateTime @default(now()) @map("imported_at")
  details     String?  @db.Text // JSON

  importer    User     @relation(fields: [importedBy], references: [id])

  @@map("import_logs")
}

// ===== V10 NEW MODELS =====

model PromotionEligibility {
  id              Int       @id @default(autoincrement())
  ctvId           Int       @map("ctv_id")
  targetRank      String    @map("target_rank")
  qualifiedMonth  String    @map("qualified_month")
  effectiveDate   DateTime  @map("effective_date")
  status          String    @default("PENDING") // PENDING, APPROVED, ACTIVATED
  approvedBy      Int?      @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  ctv             User      @relation("CtvPromotions", fields: [ctvId], references: [id])

  @@map("promotion_eligibility")
}

model TeamBonus {
  id                  Int       @id @default(autoincrement())
  ctvId               Int       @map("ctv_id")
  month               String
  directMemberCount   Int       @map("direct_member_count")
  teamRevenue         Decimal   @db.Decimal(15, 0) @map("team_revenue")
  bonusRate           Decimal   @db.Decimal(5, 4) @map("bonus_rate")
  bonusAmount         Decimal   @db.Decimal(15, 0) @map("bonus_amount")
  cashAmount          Decimal   @db.Decimal(15, 0) @map("cash_amount")
  pointAmount         Decimal   @db.Decimal(15, 0) @map("point_amount")
  status              String    @default("PENDING")
  paidAt              DateTime? @map("paid_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  ctv                 User      @relation("CtvTeamBonuses", fields: [ctvId], references: [id])

  @@map("team_bonuses")
}

model LoyaltyPoint {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  points      Int
  source      String    // TEAM_BONUS, PERSONAL_PURCHASE, MILESTONE
  referenceId Int?      @map("reference_id")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation("UserLoyaltyPoints", fields: [userId], references: [id])

  @@map("loyalty_points")
}

model ProfessionalTitle {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique @map("user_id")
  title       String    // EXPERT_LEADER, SENIOR_EXPERT, STRATEGIC_ADVISOR
  directCount Int       @map("direct_count")
  awardedAt   DateTime  @default(now()) @map("awarded_at")
  renewedAt   DateTime  @map("renewed_at")
  expiresAt   DateTime  @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  user        User      @relation(fields: [userId], references: [id])

  @@map("professional_titles")
}

// ============================================================
// V13 restored models (FeeConfig, BusinessHousehold, B2BContract,
// TrainingLog, Invoice, AutoTransferLog, TaxRecord, ManagementFee,
// BreakawayLog, BreakawayFee, AuditLog, AdminManualAction)
// ============================================================

model FeeConfig {
  id          Int      @id @default(autoincrement())
  tier        String   @unique
  minCombo    Int      @map("min_combo")
  maxCombo    Int?     @map("max_combo")
  feeAmount   Decimal  @db.Decimal(15, 0) @map("fee_amount")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("fee_config")
}

model BusinessHousehold {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  businessName    String   @map("business_name")
  taxCode         String?  @map("tax_code")
  businessLicense String?  @map("business_license")
  registeredAt    DateTime @default(now()) @map("registered_at")
  status          String   @default("active")

  dealerContractNo   String?   @map("dealer_contract_no")
  dealerSignedAt     DateTime? @map("dealer_signed_at")
  dealerExpiredAt    DateTime? @map("dealer_expired_at")
  dealerTermMonths   Int?      @default(12) @map("dealer_term_months")
  dealerPdfUrl       String?   @map("dealer_pdf_url")

  trainingContractNo   String?   @map("training_contract_no")
  trainingSignedAt     DateTime? @map("training_signed_at")
  trainingExpiredAt    DateTime? @map("training_expired_at")
  trainingTermMonths   Int?      @default(12) @map("training_term_months")
  trainingPdfUrl       String?   @map("training_pdf_url")

  bankName           String?   @map("bank_name")
  bankAccountNo      String?   @map("bank_account_no")
  bankAccountHolder  String?   @map("bank_account_holder")

  trainingLineRegistered Boolean @default(false) @map("training_line_registered")

  user            User     @relation(fields: [userId], references: [id])

  @@map("business_households")
}

model B2BContract {
  id                  Int       @id @default(autoincrement())
  contractNo          String    @unique @map("contract_no")
  trainerId           Int       @map("trainer_id")
  traineeId           Int       @map("trainee_id")
  signedAt            DateTime  @default(now()) @map("signed_at")
  expiredAt           DateTime? @map("expired_at")
  status              String    @default("active")
  terminatedAt        DateTime? @map("terminated_at")
  terminationReason   String?   @db.Text @map("termination_reason")
  terminatedBy        Int?      @map("terminated_by")

  trainer             User      @relation("Trainer", fields: [trainerId], references: [id])
  trainee             User      @relation("Trainee", fields: [traineeId], references: [id])
  invoices            Invoice[]

  @@map("b2b_contracts")
}

model TrainingLog {
  id              Int       @id @default(autoincrement())
  trainerId       Int       @map("trainer_id")
  traineeId       Int       @map("trainee_id")
  sessionDate     DateTime  @map("session_date")
  durationMinutes Int       @map("duration_minutes")
  content         String    @db.Text
  menteeConfirmed Boolean   @default(false) @map("mentee_confirmed")
  mentorConfirmed Boolean   @default(true) @map("mentor_confirmed")
  status          String    @default("PENDING")
  verifiedBy      Int?      @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  otpCode         String?   @map("otp_code")
  otpExpiresAt    DateTime? @map("otp_expires_at")
  otpSentAt       DateTime? @map("otp_sent_at")
  otpSentMethod   String?   @map("otp_sent_method")
  otpRetryCount   Int       @default(0) @map("otp_retry_count")
  otpFailCount    Int       @default(0) @map("otp_fail_count")
  otpBlockedUntil DateTime? @map("otp_blocked_until")
  adminVerified   Boolean   @default(false) @map("admin_verified")
  adminVerifiedBy Int?      @map("admin_verified_by")
  adminVerifiedAt DateTime? @map("admin_verified_at")

  trainer         User      @relation("TrainerLogs", fields: [trainerId], references: [id])
  trainee         User      @relation("TraineeLogs", fields: [traineeId], references: [id])

  @@map("training_logs")
}

model Invoice {
  id            Int      @id @default(autoincrement())
  contractId    Int?     @map("contract_id")
  fromUserId    Int      @map("from_user_id")
  toUserId      Int      @map("to_user_id")
  amount        Decimal  @db.Decimal(15, 0)
  feeTier       String   @map("fee_tier")
  invoiceNumber String   @unique @map("invoice_number")
  issuedAt      DateTime @default(now()) @map("issued_at")
  pdfUrl        String?  @map("pdf_url")
  status        String   @default("DRAFT")

  externalId     String?   @map("external_id")
  retryCount     Int       @default(0) @map("retry_count")
  lastRetryAt    DateTime? @map("last_retry_at")
  manualIssued   Boolean   @default(false) @map("manual_issued")
  issuedBy       Int?      @map("issued_by")
  issuedAtManual DateTime? @map("issued_at_manual")

  contract      B2BContract? @relation(fields: [contractId], references: [id])
  fromUser      User         @relation("InvoicesFrom", fields: [fromUserId], references: [id])
  toUser        User         @relation("InvoicesTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@map("invoices")
}

model AutoTransferLog {
  id           Int      @id @default(autoincrement())
  fromUserId   Int      @map("from_user_id")
  toUserId     Int      @map("to_user_id")
  amount       Decimal  @db.Decimal(15, 0)
  transferDate DateTime @default(now()) @map("transfer_date")
  reference    Int?
  status       String   @default("PENDING")
  errorMessage String?  @db.Text @map("error_message")

  retryCount     Int       @default(0) @map("retry_count")
  maxRetry       Int       @default(3) @map("max_retry")
  lastRetryAt    DateTime? @map("last_retry_at")
  manualResolved Boolean   @default(false) @map("manual_resolved")
  resolvedBy     Int?      @map("resolved_by")
  resolvedAt     DateTime? @map("resolved_at")
  adminNote      String?   @db.Text @map("admin_note")

  fromUser     User     @relation("TransfersFrom", fields: [fromUserId], references: [id])
  toUser       User     @relation("TransfersTo", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([status])
  @@map("auto_transfer_logs")
}

model TaxRecord {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  month          String
  taxableIncome  Decimal  @db.Decimal(15, 0) @map("taxable_income")
  taxAmount      Decimal  @db.Decimal(15, 0) @map("tax_amount")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@map("tax_records")
}

model ManagementFee {
  id         Int      @id @default(autoincrement())
  fromUserId Int      @map("from_user_id")
  toUserId   Int      @map("to_user_id")
  level      Int
  amount     Decimal  @db.Decimal(15, 0)
  month      String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser   User     @relation("MgmtFeeFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("MgmtFeeTo",   fields: [toUserId],   references: [id])

  @@index([toUserId, month])
  @@index([fromUserId, month])
  @@map("management_fees")
}

model BreakawayLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  oldParentId  Int      @map("old_parent_id")
  newParentId  Int      @map("new_parent_id")
  breakawayAt  DateTime @default(now()) @map("breakaway_at")
  expireAt     DateTime @map("expire_at")
  status       String   @default("ACTIVE")

  user         User         @relation("BreakawayUser",      fields: [userId],       references: [id])
  oldParent    User         @relation("BreakawayOldParent", fields: [oldParentId],  references: [id])
  newParent    User         @relation("BreakawayNewParent", fields: [newParentId],  references: [id])
  breakawayFees BreakawayFee[]

  @@index([status, expireAt])
  @@index([oldParentId])
  @@index([newParentId])
  @@index([status])
  @@map("breakaway_logs")
}

model BreakawayFee {
  id             Int      @id @default(autoincrement())
  breakawayLogId Int      @map("breakaway_log_id")
  fromUserId     Int      @map("from_user_id")
  toUserId       Int      @map("to_user_id")
  level          Int
  amount         Decimal  @db.Decimal(15, 0)
  month          String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")

  breakawayLog   BreakawayLog @relation(fields: [breakawayLogId], references: [id])
  fromUser       User         @relation("BreakFeeFrom", fields: [fromUserId], references: [id])
  toUser         User         @relation("BreakFeeTo",   fields: [toUserId],   references: [id])

  @@index([toUserId, month])
  @@index([breakawayLogId, month])
  @@map("breakaway_fees")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    Int?     @map("target_id")
  oldValue    String?  @db.Text @map("old_value")
  newValue    String?  @db.Text @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  status      String   @default("SUCCESS")
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())     @map("created_at")

  user        User?    @relation("AuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model AdminManualAction {
  id          Int      @id @default(autoincrement())
  adminId     Int      @map("admin_id")
  actionType  String   @map("action_type")
  targetType  String   @map("target_type")
  targetId    Int      @map("target_id")
  oldStatus   String?  @map("old_status")
  newStatus   String?  @map("new_status")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([actionType])
  @@index([targetType, targetId])
  @@map("admin_manual_actions")
}
