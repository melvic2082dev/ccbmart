# =============================================================================
# CCB Mart — Production Environment Variables
# Copy to .env and fill in all values before deploying.
# Never commit the actual .env file to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string with production pool settings
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ccbmart?connection_limit=20&pool_timeout=10

# docker-compose variables (used by docker-compose.prod.yml)
POSTGRES_DB=ccbmart
POSTGRES_USER=ccbmart
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_MINIMUM_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=https://app.ccbmart.vn,https://admin.ccbmart.vn

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.ccbmart.vn
FRONTEND_PORT=3000

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" stores files on disk; "s3" uses AWS S3
STORAGE_TYPE=s3
S3_BUCKET=ccbmart-uploads-prod
S3_REGION=ap-southeast-1
# Required if STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── MoMo Payment ─────────────────────────────────────────────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ── ZaloPay ───────────────────────────────────────────────────────────────────
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# ── KiotViet ──────────────────────────────────────────────────────────────────
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_RETAILER=

# ── Web Push Notifications ────────────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ccbmart.vn
